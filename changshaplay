  {name:'糖油粑粑',sub:'金记 · 现炸现卖',badge:'甜品',desc:'糯米粉团炸到金黄，再裹一层糖稀。外脆内糯，趁热吃才不粘牙。',shop:'金记糖油佗佗',img:'tangyou',time:'第3站 太平街'},
  {name:'幽兰拿铁',sub:'茶颜悦色 · 长沙限定',badge:'国民',desc:'只在长沙才能喝到。奶香茶醇，顶上一抹碧根果碎。',shop:'茶颜悦色 IFS店',img:'tea',time:'第5站 IFS'},
  {name:'口味虾',sub:'文和友 · 麻辣鲜香',badge:'必点',desc:'长沙夜宵的灵魂。红亮油润，麻、辣、鲜、香四味齐发，配啤酒刚好。',shop:'超级文和友',img:'crayfish',time:'第6站 文和友'},
  {name:'猪油拌粉',sub:'文和友招牌 · 简单极致',badge:'隐藏',desc:'就一碗光头粉，靠猪油、酱油、葱花三样撑场。粉吸饱油香，质朴的惊艳。',shop:'超级文和友',img:'zhuyou',time:'第6站 文和友'},
  {name:'刮凉粉',sub:'夏日解暑 · 酸辣',badge:'解腻',desc:'绿豆粉刮成条，浇酱油醋辣油花生碎。冰凉酸辣，边走边吃最对味。',shop:'太平街流动摊',img:'liangfen',time:'第3站 太平街'},
  {name:'老长沙大香肠',sub:'炸得外焦内嫩',badge:'街头',desc:'13元一根，炸得酥脆咬下去满嘴肉香，逛街必备。',shop:'文和友大香肠',img:'xiangchang',time:'第3站 太平街'}
];
document.getElementById('food-grid').innerHTML=foodData.map(f=>`
  <div class="food-card"><div class="img-wrap relative"><img src="https://picsum.photos/seed/changsha-${f.img}/600/400.jpg" alt="${f.name}"><span class="badge">${f.badge}</span></div><div class="p-5"><h3 class="font-serif font-bold text-lg mb-1">${f.name}</h3><p class="text-xs text-[var(--muted)] mb-3">${f.sub}</p><p class="text-sm text-[var(--ink-soft)] leading-relaxed">${f.desc}</p><div class="mt-4 pt-4 border-t border-[var(--line)] flex justify-between text-xs"><span class="text-[var(--muted)]">${f.time}</span><span class="text-[var(--ink)] font-medium">${f.shop}</span></div></div></div>
`).join('');

function copyAddress(addr,btn){navigator.clipboard.writeText(addr).then(()=>{btn.classList.add('copied');btn.querySelector('span').textContent='已复制';btn.querySelector('i').className='fas fa-check';setTimeout(()=>{btn.classList.remove('copied');btn.querySelector('span').textContent='复制地址';btn.querySelector('i').className='far fa-copy'},2000)}).catch(()=>{const ta=document.createElement('textarea');ta.value=addr;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);btn.querySelector('span').textContent='已复制';setTimeout(()=>{btn.querySelector('span').textContent='复制地址'},2000)})}

const map=L.map('map',{scrollWheelZoom:false,zoomControl:true}).setView([28.2005,112.9760],14);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap 贡献者',maxZoom:18,subdomains:['a','b','c']}).addTo(map);
L.polyline(itinerary.map(p=>p.coords),{color:'#C8392E',weight:2,opacity:.55,dashArray:'6, 10',lineCap:'round'}).addTo(map);
const markers={};
itinerary.forEach(p=>{const icon=L.divIcon({className:'marker-wrapper',html:`<div class="marker-pin ${p.color}" data-id="${p.id}"><span>${p.id}</span></div>`,iconSize:[34,34],iconAnchor:[17,34],popupAnchor:[0,-34]});const marker=L.marker(p.coords,{icon}).addTo(map);marker.bindPopup(`<div style="min-width:220px;"><div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;"><span style="background:${p.color==='red'?'#C8392E':'#E8A33D'};color:#fff;padding:2px 8px;border-radius:2px;font-size:11px;font-weight:600;">${p.type}</span><span style="font-size:11px;color:#8B7D6F;">${p.time} · ${p.duration}</span></div><div style="font-family:'Noto Serif SC',serif;font-weight:700;font-size:17px;color:#2A1F1A;margin-bottom:4px;">${p.name}</div><div style="font-size:11px;color:#8B7D6F;margin-bottom:8px;">${p.fullAddress}</div><div style="font-size:12px;color:#5A4A3F;line-height:1.65;border-top:1px solid #E5D7BE;padding-top:8px;">${p.desc.substring(0,90)}...</div></div>`,{maxWidth:280});marker.on('click',()=>highlightCard(p.id));markers[p.id]=marker});
function focusOnMap(id){const p=itinerary.find(x=>x.id===id);if(!p)return;map.flyTo(p.coords,15,{duration:.8});setTimeout(()=>markers[id].openPopup(),600);highlightCard(id);document.getElementById('map-section').scrollIntoView({behavior:'smooth',block:'start'})}
window.focusOnMap=focusOnMap;
function highlightCard(id){document.querySelectorAll('.stop-card').forEach(c=>c.classList.toggle('active',+c.dataset.id===id));document.querySelectorAll('.map-list-item').forEach(c=>c.classList.toggle('active',+c.dataset.id===id));document.querySelectorAll('.marker-pin').forEach(m=>m.classList.toggle('active',+m.dataset.id===id))}
window.highlightCard=highlightCard;
const io=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('in');io.unobserve(x.target)}})},{threshold:.1});document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
const countIO=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){const el=x.target,t=+el.dataset.count;let c=0;const s=Math.max(1,Math.floor(t/30));const ti=setInterval(()=>{c+=s;if(c>=t){c=t;clearInterval(ti)}el.textContent=c},40);countIO.unobserve(el)}})},{threshold:.5});document.querySelectorAll('[data-count]').forEach(el=>countIO.observe(el));
const progIO=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){const el=x.target;setTimeout(()=>el.style.width=el.dataset.width,200);progIO.unobserve(el)}})},{threshold:.5});document.querySelectorAll('.progress-fill').forEach(el=>progIO.observe(el));
const nav=document.querySelector('nav.top-nav');window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',window.scrollY>30));
</script>
